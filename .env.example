# Variables de entorno del proyecto (solo placeholders, nunca valores reales).
# Copiar a .env.local y completar para desarrollo.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Sitio
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_BASE_URL=

# Panel admin (login y sesión firmada)
ADMIN_PASSWORD=
STAFF_PASSWORD=
ADMIN_SESSION_SECRET=

# Google Reviews (opcional: la Home muestra fallback si faltan)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Rate limit durable (opcional: sin Upstash usa memoria local)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# WhatsApp Cloud API — carga de Finanzas por texto (opcional; sin estas
# variables el módulo queda desactivado y la app sigue funcionando).
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ALLOWED_NUMBERS=
WHATSAPP_APP_SECRET=
